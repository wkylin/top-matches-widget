  exec "$basedir/node"  "$basedir/../.pnpm/concurrently@10.0.3/node_modules/concurrently/dist/bin/index.js" "$@"
else
  exec node  "$basedir/../.pnpm/concurrently@10.0.3/node_modules/concurrently/dist/bin/index.js" "$@"
